@page "/events/add"
@using EventEaseApp2.Services
@inject EventService EventService
@inject NavigationManager Navigation

<PageTitle>Add Event</PageTitle>

<div class="add-event-container">
    <div class="form-card">
        <div class="form-header">
            <h1>Create New Event</h1>
            <p>Share your event with the community</p>
        </div>

        <div class="form-content">
            <div class="form-group">
                <label for="eventName" class="form-label">
                    <span class="bi bi-pencil-square"></span> Event Name
                </label>
                <input type="text" id="eventName" class="form-control modern-input" @bind:event="oninput" @bind="EventName" maxlength="500" placeholder="Enter event name" />
                <div class="character-count">@EventName.Length / 500</div>
            </div>

            <div class="form-group">
                <label for="eventDate" class="form-label">
                    <span class="bi bi-calendar-event"></span> Date
                </label>
                <input type="date" id="eventDate" class="form-control modern-input" @bind="EventDate" />
            </div>

            <div class="form-group">
                <label for="eventLocation" class="form-label">
                    <span class="bi bi-geo-alt-fill"></span> Location
                </label>
                <input type="text" id="eventLocation" class="form-control modern-input" @bind:event="oninput" @bind="EventLocation" maxlength="500" placeholder="Enter event location" />
                <div class="character-count">@EventLocation.Length / 500</div>
            </div>

            <div class="form-actions">
                <button class="btn btn-submit" @onclick="HandleAddEvent">
                    <span class="bi bi-plus-circle-fill"></span> Create Event
                </button>
                <NavLink href="/events" class="btn btn-cancel">
                    <span class="bi bi-x-circle-fill"></span> Cancel
                </NavLink>
            </div>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="error-alert">
                    <span class="bi bi-exclamation-triangle-fill"></span>
                    <span>@ErrorMessage</span>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .add-event-container {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .form-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
        max-width: 500px;
        width: 100%;
        overflow: hidden;
    }

    .form-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 2rem 1.5rem;
        text-align: center;
    }

    .form-header h1 {
        font-size: 1.8rem;
        font-weight: 700;
        margin: 0 0 0.5rem 0;
    }

    .form-header p {
        font-size: 0.95rem;
        margin: 0;
        opacity: 0.9;
    }

    .form-content {
        padding: 2rem 1.5rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 600;
        color: #333;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .form-label .bi {
        color: #667eea;
        font-size: 1.1rem;
    }

    .character-count {
        font-size: 0.8rem;
        color: #999;
        margin-top: 0.35rem;
        text-align: right;
    }

    .modern-input {
        width: 100%;
        padding: 0.875rem;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        font-family: inherit;
    }

    .modern-input:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }

    .btn-submit,
    .btn-cancel {
        flex: 1;
        padding: 0.875rem;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        text-decoration: none;
    }

    .btn-submit {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.6);
        color: white;
    }

    .btn-cancel {
        background: #f0f0f0;
        color: #333;
    }

    .btn-cancel:hover {
        background: #e0e0e0;
        color: #333;
        text-decoration: none;
    }

    .error-alert {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: #fee;
        border: 1px solid #fcc;
        color: #c33;
        padding: 1rem;
        border-radius: 8px;
        margin-top: 1.5rem;
        font-size: 0.95rem;
    }

    .error-alert .bi {
        font-size: 1.2rem;
    }
</style>

@code {
    private string EventName = string.Empty;
    private DateTime EventDate = DateTime.Today.AddDays(1);
    private string EventLocation = string.Empty;
    private string ErrorMessage = string.Empty;

    private void HandleAddEvent()
    {
        ErrorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(EventName))
        {
            ErrorMessage = "Event name is required.";
            return;
        }

        if (EventName.Length > 500)
        {
            ErrorMessage = "Event name cannot exceed 500 characters.";
            return;
        }

        if (string.IsNullOrWhiteSpace(EventLocation))
        {
            ErrorMessage = "Location is required.";
            return;
        }

        if (EventLocation.Length > 500)
        {
            ErrorMessage = "Location cannot exceed 500 characters.";
            return;
        }

        if (EventDate < DateTime.Today)
        {
            ErrorMessage = "Event date cannot be in the past.";
            return;
        }

        try
        {
            EventService.AddEvent(EventName, EventDate, EventLocation);
            Navigation.NavigateTo("/events");
        }
        catch (ArgumentException ex)
        {
            ErrorMessage = ex.Message;
        }
    }
}
